# Normalize text files to LF in the repository and working tree.
* text=auto eol=lf

# Source and scripts
*.ahk         text eol=lf
*.rs          text eol=lf
*.ps1         text eol=lf
*.bat         text eol=lf

# Project metadata and structured data
*.md          text eol=lf
*.txt         text eol=lf
*.ini         text eol=lf
*.toml        text eol=lf
*.json        text eol=lf
*.xml         text eol=lf
*.csv         text eol=lf
*.html        text eol=lf
*.editorconfig text eol=lf
*.gitignore   text eol=lf
*.gitkeep     text eol=lf
LICENSE      text eol=lf

# Binary assets and generated/helper binaries
*.png         binary
*.jpg         binary
*.jpeg        binary
*.gif         binary
*.webp        binary
*.ico         binary
*.ttf         binary
*.woff        binary
*.woff2       binary
*.exe         binary
*.dll         binary
*.dat         binary
*.bak         binary
